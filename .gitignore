# Ignore the contents of the _site directory and other cache directories
_site/
.sass-cache/

# Ignore the directory for local files during development
local/

# Ignore the Gemfile that is generated
Gemfile.lock

# Ingore files created by npm
node_modules
package-lock.json

# LaTeX source archives should not be committed.
latex/*.zip

# LaTeX build artifacts.
latex/**/build/
latex/.texlive-cache/
latex/**/*.aux
latex/**/*.bbl
latex/**/*.bcf
latex/**/*.blg
latex/**/*.fdb_latexmk
latex/**/*.fls
latex/**/*.log
latex/**/*.out
latex/**/*.run.xml
latex/**/*.synctex.gz
latex/**/*.toc
